{
  "expo": {
    "name": "commit",
    "slug": "commit",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "commit",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.commit.mobile"
    },
    "android": {
      "package": "app.commit.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow commit to access your camera so you can take proof photos."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow commit to access your microphone for 30-second voice memos on your drops."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "newArchEnabled": true
  }
}
