{
  "expo": {
    "name": "commit",
    "slug": "commit",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "commit",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.commit.mobile"
    },
    "android": {
      "package": "app.commit.mobile"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "newArchEnabled": true
  }
}
