{
  "expo": {
    "name": "commit",
    "slug": "commit",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "commit",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.commit.mobile"
    },
    "android": {
      "package": "app.commit.mobile",
      "backgroundColor": "#050505",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050505"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#050505"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow commit to access your camera so you can take proof photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow commit to access your photos so you can set a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "newArchEnabled": true
  }
}
